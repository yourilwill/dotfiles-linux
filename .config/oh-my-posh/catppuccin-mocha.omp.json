{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "background": "#181825",
          "foreground": "#cdd6f4",
          "leading_diamond": "",
          "style": "diamond",
          "template": "{{ .UserName }}@{{ .HostName }} ",
          "type": "session"
        },
        {
          "background": "#cba6f7",
          "foreground": "#1e1e2e",
          "powerline_symbol": "",
          "options": {
            "style": "letter"
          },
          "style": "powerline",
          "template": " {{ .Path }} ",
          "type": "path"
        },
        {
          "background": "#a6e3a1",
          "background_templates": [
            "{{ if gt .Conflicted 0 }}#f38ba8{{ end }}",
            "{{ if or .Working.Changed .Staging.Changed }}#f9e2af{{ end }}"
          ],
          "foreground": "#1e1e2e",
          "powerline_symbol": "",
          "options": {
            "branch_icon": "",
            "fetch_status": true,
            "fetch_upstream_icon": false
          },
          "style": "powerline",
          "template": "  ({{ .HEAD }}{{ if gt .StashCount 0 }}  {{ .StashCount }}{{ end }}) ",
          "type": "git"
        },
        {
          "background": "#313244",
          "foreground": "#89dceb",
          "powerline_symbol": "",
          "style": "powerline",
          "template": "  {{ if .PackageManagerIcon }}{{ .PackageManagerIcon }} {{ end }}{{ .Full }} ",
          "type": "node"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "segments": [
        {
          "background": "#45475a",
          "foreground": "#f9e2af",
          "invert_powerline": true,
          "leading_diamond": "",
          "style": "diamond",
          "template": "  {{.Profile}}{{if .Region}}@{{.Region}}{{end}}",
          "trailing_diamond": "",
          "type": "aws"
        }
      ],
      "type": "rprompt"
    }
  ],
  "final_space": true,
  "version": 4
}
